# Start ZSH
{{ if eq .chezmoi.os "darwin" -}}
command = /opt/homebrew/bin/zsh --login --interactive
font-size = 12
# font-thicken = true
# font-thicken-strength = 40
{{ else if eq .chezmoi.os "linux" -}}
# Optional: Adjust font size
font-size = 11
# command = /home/linuxbrew/.linuxbrew/bin/zsh --login --interactive
command = /usr/bin/zsh --login --interactive
# command = /usr/bin/bash -c 'distrobox enter dev'
{{ end }}

# Ghostty Configuration for JetBrainsMono Nerd Font Mono

theme = "Kanagawa Dragon"

font-family = "CaskaydiaMono Nerd Font Mono"
font-family-italic = "CaskaydiaMono Nerd Font Mono Italic"
font-family-bold = "CaskaydiaMono Nerd Font Mono Bold"
font-family-bold-italic = "CaskaydiaMono Nerd Font Mono Bold Italic"

# Use xterm-256color to match tmux
# Otherwise there is significant lag in Neovim
term = "xterm-256color"

# Clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = true
