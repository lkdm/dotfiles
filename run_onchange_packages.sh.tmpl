#!/usr/bin/env bash

# This file declaratively installs packages. If it has changed between chezmoi applications,
# this script will be executed.
#
dev_packages=(
  # Lua
  # lua luarocks
  # JavaScript
  # fnm bun
  # Docker
  docker docker-compose
  # Python
  uv pipx python
  # Git
  jesseduffield/lazygit/lazygit git-delta
  # Data
  jq xsv up
  # Org
  jira-cli
  # Environment management
  mise
  # Run LLMs locally
  ollama
)
# brew tap oven-sh/bun
# brew tap omnisharp/omnisharp-roslyn
for package in "${dev_packages[@]}"; do
  echo "Installing dev package: $package..."
  $(which brew) install --quiet "$package" || echo "Failed: $package"
done

# Install the latest version of Node
# NODE_LATEST="$(fnm list-remote | tail -1 | sed 's/^v//')"
# fnm install "$NODE_LATEST"
# fnm default "$NODE_LATEST"

# Symlink Omnnisharp
# ln -s $(which OmniSharp) ~/.local/bin/omnisharp

{{- if eq .chezmoi.os "linux" }}
# Install 1Password on Linux
brew tap "ublue-os/tap"
brew install --cask 1password-gui-linux
{{- end }}

#
# Brew packages
brew_packages=(
  # shells
  bash zsh
  # shell enhancements
  atuin fzf fd bat ripgrep
  # development
  git bob tmux jrnl tz
  # xh - great curl alternative
  # https://github.com/ducaale/xh
  xh
  # starship - fast, configurable terminal prompt written in Rust
  starship
  # trippy - ping and traceroute in one
  trippy
  # eza - drop-in replacement for ls
  eza
  # asciinema - used to create a textual video of a terminal sesssion
  # agg - used to convert asciicast format to gif
  asciinema agg
  {{- if (eq .sysarea "home")}}
  ffmpeg pandoc
  {{- end }}

  {{- if (eq .sysarea "work")}}
  awscli
  kubernetes-cli
  mysql-client
  {{- end }}

  {{- if or (eq .sysarea "home") (eq .sysarea "work")}}
    btop
    mosh
    sevenzip
  {{- end }}

  {{- if eq .chezmoi.os "linux" }}
    {{- if or (eq .sysarea "server") (eq .sysarea "devcontainer")}}
      # xsel works better when sshing into a container
      xsel
    {{- else }}
      xclip
    {{- end }}
  {{- end }}

)
brew tap "jesseduffield/lazygit"
brew tap "nikitabobko/tap"
for package in "${brew_packages[@]}"; do
  echo "Installing brew package: $package..."
  $(which brew) install --quiet "$package" || echo "Failed: $package"
done

# Use the correct Neovim version
bob install 0.11.6
bob use 0.11.6

{{- if eq .chezmoi.os "darwin" }}
# Install cask packages, available on MacOS
brew_casks=(
  ghostty
  obsidian
  firefox
  1password
  1password-cli
{{- if eq .sysarea "home"}}
  iina
  discord
  scrivener
  calibre
  cryptomator
{{- end }}
)
for package in "${brew_casks[@]}"; do
  echo "Installing brew cask: $package..."
  $(which brew) install --cask --quiet "$package" || echo "Failed: $package"
done


{{- if eq .sysarea "home"}}
# # Install apps from the MacOS app store
apps=(
  904280696    # Things 3
  937984704    # Amphetamine
  1464122853   # NextDNS
)
brew install mas
for package in "${apps[@]}"; do
  echo "Installing App store app: $package..."
  mas install "$package"
done
{{- end }}
{{- end }}

{{- if eq .chezmoi.os "linux" }}
# Flatpak packages on Linux
flatpak_packages=(
  com.discordapp.Discord
  com.spotify.Client
  org.localsend.localsend_app
  it.mijorus.gearlever
  com.libreoffice.LibreOffice
  org.zealdocs.Zeal
  {{- if eq .sysarea "home"}}
    org.remmina.Remmina
    it.fabiodistasio.AntaresSQL
    org.chromium.Chromium
  {{- end }}
)
flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
for package in "${flatpak_packages[@]}"; do
  echo "Installing Flatpak package: $package..."
  flatpak install -y flathub "$package"
done
{{- end }}

python_packages=(
)
for package in "${python_packages[@]}"; do
  echo "Installing Python tool through uv: $package..."
  uv tool install $package
done


cargo_packages=(
  lazyllama
)
for package in "${cargo_packages[@]}"; do
  echo "Installing Cargo tool: $package..."
  cargo install --locked $package
done

#### USER SCRIPTS
cargo_userscripts=()
for package in "${cargo_userscripts[@]}"; do
  echo "Installing Cargo userscript: $package..."
  cargo install --git https://github.com/lkdm/scripts $package --force 
done

